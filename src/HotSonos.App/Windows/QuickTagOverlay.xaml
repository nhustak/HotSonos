<Window x:Class="HotSonos.App.Windows.QuickTagOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HotSonos Quick Tag"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterScreen"
        PreviewKeyDown="Window_PreviewKeyDown"
        Deactivated="Window_Deactivated">
    <Border Background="#F0141C28" BorderBrush="#FF2ECC71" BorderThickness="2" CornerRadius="12" Padding="18,14">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.55" Color="#FF000000" />
        </Border.Effect>
        <StackPanel MinWidth="360" MaxWidth="480">
            <TextBlock Text="Quick tag" FontSize="18" FontWeight="SemiBold" Foreground="#FFE8EEF4" />
            <TextBlock x:Name="NowPlayingText" Margin="0,6,0,4" FontSize="13" Foreground="#FFB8C4D0"
                       TextWrapping="Wrap" Text="(resolving now playing…)" />
            <TextBlock x:Name="PathText" FontSize="11" Foreground="#FF708090" TextWrapping="Wrap" Margin="0,0,0,10" />
            <TextBlock x:Name="StatusText" FontSize="12" Foreground="#FFF0C040" TextWrapping="Wrap" Margin="0,0,0,8"
                       Visibility="Collapsed" />
            <ItemsControl x:Name="PresetList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,3" Padding="10,8" CornerRadius="6" Background="#FF1C2536" BorderBrush="#FF3A4A5C" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Slot}" FontSize="18" FontWeight="Bold"
                                           Foreground="#FF2ECC71" VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Label}" FontSize="14" FontWeight="SemiBold" Foreground="#FFE8EEF4" />
                                    <TextBlock Text="{Binding Summary}" FontSize="11" Foreground="#FF90A0B0" TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <TextBlock Margin="0,10,0,0" FontSize="11" Foreground="#FF708090"
                       Text="1–9 apply · Esc cancel" HorizontalAlignment="Center" />
        </StackPanel>
    </Border>
</Window>
