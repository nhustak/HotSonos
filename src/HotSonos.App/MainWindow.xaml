<Window x:Class="HotSonos.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HotSonos"
        Width="540" Height="640"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI" FontSize="13"
        Background="#FFF4F6F8">
    <Window.Resources>
        <Style TargetType="TextBlock" x:Key="SectionHeader">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#FF1C2536" />
            <Setter Property="Margin" Value="0,14,0,6" />
        </Style>
        <Style TargetType="TextBox" x:Key="HotkeyBox">
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="Width" Value="170" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header: room + refresh -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Target room / group" Style="{StaticResource SectionHeader}" Margin="0,0,0,6" />
            <StackPanel Orientation="Horizontal">
                <ComboBox x:Name="RoomComboBox" Width="300" Height="28"
                          VerticalContentAlignment="Center"
                          SelectionChanged="RoomComboBox_SelectionChanged" />
                <Button x:Name="RefreshButton" Content="Refresh devices" Height="28" Margin="10,0,0,0"
                        Padding="10,0" Click="RefreshButton_Click" />
            </StackPanel>
            <TextBlock Text="Hotkeys control this room. Grouped rooms follow their coordinator automatically."
                       Foreground="#FF60707F" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap" />
        </StackPanel>

        <!-- Scrollable body -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
            <StackPanel>
                <Border Background="#FFEAF8F0" CornerRadius="6" Padding="12" Margin="0,8,0,4"
                        BorderBrush="#FF2ECC71" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="🔀 Shuffle my Music Library" FontSize="15" FontWeight="SemiBold"
                                   Foreground="#FF1C2536" />
                        <TextBlock Text="One hotkey to shuffle-play your entire local music library on the selected speakers."
                                   Foreground="#FF60707F" FontSize="11" Margin="0,2,0,8" TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Hotkey" VerticalAlignment="Center" Width="120" />
                            <TextBox x:Name="ShuffleHotkeyBox" Style="{StaticResource HotkeyBox}"
                                     PreviewKeyDown="HotkeyBox_PreviewKeyDown" GotFocus="HotkeyBox_GotFocus" />
                            <Button Content="Clear" Margin="8,0" Padding="8,0" Tag="Shuffle" Click="ClearHotkey_Click" />
                        </StackPanel>

                        <Separator Margin="0,12,0,10" Background="#FF2ECC71" Opacity="0.4" />

                        <TextBlock Text="🔄 Restart fresh" FontSize="15" FontWeight="SemiBold" Foreground="#FF1C2536" />
                        <TextBlock Text="Re-discovers speakers, regroups them all (clears out-of-sync), and starts a brand-new shuffle. Use this if speakers drift out of sync."
                                   Foreground="#FF60707F" FontSize="11" Margin="0,2,0,8" TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal">
                            <Button Content="🔄  Restart fresh now" Height="32" Padding="14,0" Margin="0,0,12,0"
                                    Background="#FF1C8E54" Foreground="White" FontWeight="SemiBold"
                                    Click="FreshStartButton_Click" />
                            <TextBlock Text="Hotkey" VerticalAlignment="Center" Margin="8,0,6,0" />
                            <TextBox x:Name="FreshStartHotkeyBox" Style="{StaticResource HotkeyBox}" Width="130"
                                     PreviewKeyDown="HotkeyBox_PreviewKeyDown" GotFocus="HotkeyBox_GotFocus" />
                            <Button Content="Clear" Margin="8,0" Padding="8,0" Tag="FreshStart" Click="ClearHotkey_Click" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <TextBlock Text="Transport hotkeys" Style="{StaticResource SectionHeader}" />
                <TextBlock Text="Click a box and press your key combo (e.g. Ctrl+Alt+F9). Press Esc to clear."
                           Foreground="#FF60707F" FontSize="11" Margin="0,0,0,8" TextWrapping="Wrap" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Play / Pause" VerticalAlignment="Center" Margin="0,4" />
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="PlayPauseHotkeyBox" Style="{StaticResource HotkeyBox}"
                             Margin="0,4" PreviewKeyDown="HotkeyBox_PreviewKeyDown" GotFocus="HotkeyBox_GotFocus" />
                    <Button Grid.Row="0" Grid.Column="2" Content="Clear" Margin="8,4" Padding="8,0" Tag="PlayPause"
                            Click="ClearHotkey_Click" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Next track" VerticalAlignment="Center" Margin="0,4" />
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="NextHotkeyBox" Style="{StaticResource HotkeyBox}"
                             Margin="0,4" PreviewKeyDown="HotkeyBox_PreviewKeyDown" GotFocus="HotkeyBox_GotFocus" />
                    <Button Grid.Row="1" Grid.Column="2" Content="Clear" Margin="8,4" Padding="8,0" Tag="Next"
                            Click="ClearHotkey_Click" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Previous track" VerticalAlignment="Center" Margin="0,4" />
                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="PreviousHotkeyBox" Style="{StaticResource HotkeyBox}"
                             Margin="0,4" PreviewKeyDown="HotkeyBox_PreviewKeyDown" GotFocus="HotkeyBox_GotFocus" />
                    <Button Grid.Row="2" Grid.Column="2" Content="Clear" Margin="8,4" Padding="8,0" Tag="Previous"
                            Click="ClearHotkey_Click" />
                </Grid>

                <TextBlock Text="Volume hotkeys (all speakers)" Style="{StaticResource SectionHeader}" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Volume up" VerticalAlignment="Center" Margin="0,4" />
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="VolumeUpHotkeyBox" Style="{StaticResource HotkeyBox}"
                             Margin="0,4" PreviewKeyDown="HotkeyBox_PreviewKeyDown" GotFocus="HotkeyBox_GotFocus" />
                    <Button Grid.Row="0" Grid.Column="2" Content="Clear" Margin="8,4" Padding="8,0" Tag="VolumeUp"
                            Click="ClearHotkey_Click" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Volume down" VerticalAlignment="Center" Margin="0,4" />
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="VolumeDownHotkeyBox" Style="{StaticResource HotkeyBox}"
                             Margin="0,4" PreviewKeyDown="HotkeyBox_PreviewKeyDown" GotFocus="HotkeyBox_GotFocus" />
                    <Button Grid.Row="1" Grid.Column="2" Content="Clear" Margin="8,4" Padding="8,0" Tag="VolumeDown"
                            Click="ClearHotkey_Click" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Mute toggle" VerticalAlignment="Center" Margin="0,4" />
                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="MuteHotkeyBox" Style="{StaticResource HotkeyBox}"
                             Margin="0,4" PreviewKeyDown="HotkeyBox_PreviewKeyDown" GotFocus="HotkeyBox_GotFocus" />
                    <Button Grid.Row="2" Grid.Column="2" Content="Clear" Margin="8,4" Padding="8,0" Tag="Mute"
                            Click="ClearHotkey_Click" />
                </Grid>
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Text="Step per press (%)" VerticalAlignment="Center" Width="120" />
                    <TextBox x:Name="VolumeStepBox" Width="50" Padding="6,4" VerticalContentAlignment="Center" />
                </StackPanel>

                <TextBlock Text="Playlist / favorite hotkeys (4 slots)" Style="{StaticResource SectionHeader}" />
                <TextBlock Text="Pick a Sonos favorite or playlist for each slot, then assign a hotkey."
                           Foreground="#FF60707F" FontSize="11" Margin="0,0,0,8" TextWrapping="Wrap" />

                <Grid x:Name="FavoritesGrid">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Slot 1 -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Slot 1" VerticalAlignment="Center" Margin="0,4" />
                    <ComboBox Grid.Row="0" Grid.Column="1" x:Name="Fav1NameCombo" Height="26" Margin="0,4"
                              VerticalContentAlignment="Center" />
                    <TextBox Grid.Row="0" Grid.Column="2" x:Name="Fav1HotkeyBox" Style="{StaticResource HotkeyBox}"
                             Width="140" Margin="8,4" PreviewKeyDown="HotkeyBox_PreviewKeyDown" GotFocus="HotkeyBox_GotFocus" />
                    <Button Grid.Row="0" Grid.Column="3" Content="Clear" Margin="8,4" Padding="8,0" Tag="Fav1"
                            Click="ClearHotkey_Click" />

                    <!-- Slot 2 -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Slot 2" VerticalAlignment="Center" Margin="0,4" />
                    <ComboBox Grid.Row="1" Grid.Column="1" x:Name="Fav2NameCombo" Height="26" Margin="0,4"
                              VerticalContentAlignment="Center" />
                    <TextBox Grid.Row="1" Grid.Column="2" x:Name="Fav2HotkeyBox" Style="{StaticResource HotkeyBox}"
                             Width="140" Margin="8,4" PreviewKeyDown="HotkeyBox_PreviewKeyDown" GotFocus="HotkeyBox_GotFocus" />
                    <Button Grid.Row="1" Grid.Column="3" Content="Clear" Margin="8,4" Padding="8,0" Tag="Fav2"
                            Click="ClearHotkey_Click" />

                    <!-- Slot 3 -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Slot 3" VerticalAlignment="Center" Margin="0,4" />
                    <ComboBox Grid.Row="2" Grid.Column="1" x:Name="Fav3NameCombo" Height="26" Margin="0,4"
                              VerticalContentAlignment="Center" />
                    <TextBox Grid.Row="2" Grid.Column="2" x:Name="Fav3HotkeyBox" Style="{StaticResource HotkeyBox}"
                             Width="140" Margin="8,4" PreviewKeyDown="HotkeyBox_PreviewKeyDown" GotFocus="HotkeyBox_GotFocus" />
                    <Button Grid.Row="2" Grid.Column="3" Content="Clear" Margin="8,4" Padding="8,0" Tag="Fav3"
                            Click="ClearHotkey_Click" />

                    <!-- Slot 4 -->
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Slot 4" VerticalAlignment="Center" Margin="0,4" />
                    <ComboBox Grid.Row="3" Grid.Column="1" x:Name="Fav4NameCombo" Height="26" Margin="0,4"
                              VerticalContentAlignment="Center" />
                    <TextBox Grid.Row="3" Grid.Column="2" x:Name="Fav4HotkeyBox" Style="{StaticResource HotkeyBox}"
                             Width="140" Margin="8,4" PreviewKeyDown="HotkeyBox_PreviewKeyDown" GotFocus="HotkeyBox_GotFocus" />
                    <Button Grid.Row="3" Grid.Column="3" Content="Clear" Margin="8,4" Padding="8,0" Tag="Fav4"
                            Click="ClearHotkey_Click" />
                </Grid>

                <TextBlock Text="Now-Playing flyout" Style="{StaticResource SectionHeader}" />
                <CheckBox x:Name="FlyoutOnTrackChangeCheckBox" Content="Pop the flyout on every track change" Margin="0,2" />
                <CheckBox x:Name="FlyoutOnActionCheckBox" Content="Pop the flyout when I use a hotkey or action" Margin="0,6" />
                <TextBlock Text="Tip: drag the flyout to reposition it; click the 📌 to keep it on-screen."
                           Foreground="#FF60707F" FontSize="11" Margin="0,2,0,0" TextWrapping="Wrap" />

                <TextBlock Text="Options" Style="{StaticResource SectionHeader}" />
                <CheckBox x:Name="StartWithWindowsCheckBox" Content="Start HotSonos with Windows" Margin="0,6"
                          Checked="StartWithWindows_Changed" Unchecked="StartWithWindows_Changed" />
                <StackPanel Orientation="Horizontal" Margin="0,6">
                    <CheckBox x:Name="NightlyResetCheckBox" Content="Re-sync all speakers nightly at" VerticalAlignment="Center" />
                    <TextBox x:Name="NightlyResetTimeBox" Width="60" Margin="8,0,0,0" Padding="6,2"
                             VerticalContentAlignment="Center" />
                    <TextBlock Text="(24-hour, e.g. 03:00)" VerticalAlignment="Center" Margin="8,0,0,0"
                               Foreground="#FF60707F" FontSize="11" />
                </StackPanel>
                <TextBlock Text="Silently regroups every speaker so they start the day in sync. Skipped automatically if anything is playing — it will never start music on its own."
                           Foreground="#FF60707F" FontSize="11" Margin="0,2,0,0" TextWrapping="Wrap" />
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StatusText" Grid.Column="0" VerticalAlignment="Center"
                       Foreground="#FF2E7D46" TextWrapping="Wrap" />
            <Button Grid.Column="1" Content="Hide to tray" Height="30" Padding="14,0" Margin="0,0,8,0"
                    Click="HideButton_Click" />
            <Button Grid.Column="2" x:Name="SaveButton" Content="Save" Height="30" Padding="20,0"
                    Background="#FF2ECC71" Foreground="White" FontWeight="SemiBold"
                    Click="SaveButton_Click" />
        </Grid>
    </Grid>
</Window>
