<Window x:Class="HotSonos.App.Windows.NowPlayingFlyout"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        ShowActivated="False"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Border CornerRadius="12" Padding="14" Width="360"
            Background="#F01C2536" BorderBrush="#FF2ECC71" BorderThickness="1.5">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border x:Name="ArtBorder" Grid.Column="0" Width="72" Height="72" CornerRadius="8"
                    Background="#FF2A3850" VerticalAlignment="Top" Margin="0,0,12,0" ClipToBounds="True">
                <Image x:Name="ArtImage" Stretch="UniformToFill" />
            </Border>

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock x:Name="TitleText" Foreground="White" FontFamily="Segoe UI" FontSize="16"
                           FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Text="Nothing playing" />
                <TextBlock x:Name="ArtistText" Foreground="#FFAEC0D2" FontFamily="Segoe UI" FontSize="13"
                           TextTrimming="CharacterEllipsis" Margin="0,2,0,0" Text="" />
                <TextBlock x:Name="StatusText" Foreground="#FF2ECC71" FontFamily="Segoe UI" FontSize="12"
                           Margin="0,6,0,0" Text="" />
            </StackPanel>

            <ToggleButton x:Name="PinButton" Grid.Column="2" VerticalAlignment="Top" HorizontalAlignment="Right"
                          Width="26" Height="26" Content="📌" FontSize="13" Cursor="Hand"
                          Background="Transparent" BorderThickness="0" Foreground="#FF8090A0"
                          ToolTip="Pin (keep on screen)" Checked="PinButton_Changed" Unchecked="PinButton_Changed" />
        </Grid>
    </Border>
</Window>
